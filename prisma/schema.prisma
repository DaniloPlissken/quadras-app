generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id @default(cuid())
  name     String?
  email    String    @unique
  password String
  reservas Reserva[]
}

model Modalidade {
  id      String   @id @default(cuid())
  nome    String   @unique
  quadras Quadra[]
}

model Quadra {
  id           String     @id @default(cuid())
  nome         String
  modalidadeId String
  modalidade   Modalidade @relation(fields: [modalidadeId], references: [id])
  reservas     Reserva[]

  @@unique([nome, modalidadeId])
}

model Reserva {
  id       String   @id @default(cuid())
  userId   String
  quadraId String
  data     DateTime
  slot     String
  quadra   Quadra   @relation(fields: [quadraId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([data, slot, quadraId])
  @@unique([data, userId])
}
